# =============================================================================
# Nexus-LLM Environment Configuration 
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------
NEXUS_APP_NAME=Nexus-LLM
NEXUS_ENV=development                        # development, staging, production
NEXUS_DEBUG=true                             # Enable debug mode
NEXUS_LOG_LEVEL=INFO                         # DEBUG, INFO, WARNING, ERROR, CRITICAL
NEXUS_LOG_FORMAT=json                        # json, text

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
NEXUS_MODEL=meta-llama/Llama-3.1-8B-Instruct # Default model to load
NEXUS_MODEL_DIR=./models                     # Local model directory
NEXUS_MAX_MODEL_LEN=8192                     # Maximum sequence length
NEXUS_TRUST_REMOTE_CODE=true                 # Allow remote code execution for models

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NEXUS_HOST=0.0.0.0                           # Server bind address
NEXUS_PORT=8000                              # Server port
NEXUS_WORKERS=4                              # Number of worker processes
NEXUS_CORS_ORIGINS=["*"]                     # Allowed CORS origins
NEXUS_API_PREFIX=/v1                         # API route prefix

# -----------------------------------------------------------------------------
# GPU Configuration
# -----------------------------------------------------------------------------
NEXUS_GPU_IDS=0                              # Comma-separated GPU device IDs
NEXUS_GPU_MEMORY_UTILIZATION=0.9             # GPU memory fraction to use (0.0-1.0)
NEXUS_TENSOR_PARALLEL_SIZE=1                 # Tensor parallelism degree
NEXUS_PIPELINE_PARALLEL_SIZE=1               # Pipeline parallelism degree

# -----------------------------------------------------------------------------
# Quantization
# -----------------------------------------------------------------------------
NEXUS_QUANTIZE=none                          # none, gptq, awq, ggml
NEXUS_QUANTIZE_BITS=4                        # Quantization bits (4 or 8)
NEXUS_GPTQ_CHECKPOINT=                       # Path to GPTQ checkpoint
NEXUS_AWQ_CHECKPOINT=                        # Path to AWQ checkpoint

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
NEXUS_API_KEY=                               # Master API key (generate with: openssl rand -hex 32)
NEXUS_JWT_SECRET=                            # JWT signing secret
NEXUS_JWT_EXPIRATION=86400                   # JWT token lifetime in seconds (24h)
NEXUS_RATE_LIMIT=100/minute                  # Rate limit per API key
NEXUS_ADMIN_PASSWORD=                        # Admin dashboard password

# -----------------------------------------------------------------------------
# RAG Configuration
# -----------------------------------------------------------------------------
NEXUS_RAG_ENABLED=false                      # Enable RAG pipeline
NEXUS_VECTOR_STORE=chroma                    # chroma, faiss, milvus, pinecone, qdrant, weaviate
NEXUS_VECTOR_STORE_PATH=./data/vector_store  # Local vector store path
NEXUS_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5 # Embedding model
NEXUS_EMBEDDING_DEVICE=cpu                   # cpu, cuda
NEXUS_CHUNK_SIZE=512                         # Document chunk size (tokens)
NEXUS_CHUNK_OVERLAP=64                       # Chunk overlap (tokens)
NEXUS_CHUNK_STRATEGY=recursive               # recursive, semantic, fixed, sentence
NEXUS_TOP_K=5                                # Number of documents to retrieve
NEXUS_RERANKER_MODEL=                        # Optional reranker model

# -----------------------------------------------------------------------------
# Pinecone (if using Pinecone vector store)
# -----------------------------------------------------------------------------
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=nexus-llm

# -----------------------------------------------------------------------------
# Milvus (if using Milvus vector store)
# -----------------------------------------------------------------------------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# -----------------------------------------------------------------------------
# Qdrant (if using Qdrant vector store)
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=nexus-llm

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------
NEXUS_AGENTS_ENABLED=false                   # Enable agent framework
NEXUS_AGENT_MAX_ITERATIONS=10                # Maximum agent loop iterations
NEXUS_AGENT_TIMEOUT=300                      # Agent timeout in seconds
NEXUS_AGENT_TOOLS=web_search,calculator      # Comma-separated enabled tools

# -----------------------------------------------------------------------------
# Tool: Web Search
# -----------------------------------------------------------------------------
WEB_SEARCH_PROVIDER=serpapi                  # serpapi, tavily, google
SERPAPI_KEY=
TAVILY_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# -----------------------------------------------------------------------------
# Tool: Code Execution
# -----------------------------------------------------------------------------
CODE_EXECUTION_ENABLED=false                 # Enable code execution tool
CODE_EXECUTION_TIMEOUT=30                    # Execution timeout in seconds
CODE_EXECUTION_SANDBOX=true                  # Run in sandboxed environment

# -----------------------------------------------------------------------------
# Caching
# -----------------------------------------------------------------------------
NEXUS_CACHE_ENABLED=true                     # Enable response caching
NEXUS_CACHE_BACKEND=redis                    # memory, redis, file
NEXUS_CACHE_TTL=3600                         # Cache TTL in seconds
REDIS_URL=redis://localhost:6379/0           # Redis connection URL

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
NEXUS_TELEMETRY_ENABLED=false                # Enable OpenTelemetry tracing
NEXUS_OTEL_ENDPOINT=http://localhost:4317     # OpenTelemetry collector endpoint
NEXUS_PROMETHEUS_ENABLED=true                # Enable Prometheus metrics
NEXUS_PROMETHEUS_PORT=9090                   # Prometheus metrics port

# -----------------------------------------------------------------------------
# Weights & Biases
# -----------------------------------------------------------------------------
WANDB_ENABLED=false
WANDB_PROJECT=nexus-llm
WANDB_ENTITY=
WANDB_API_KEY=

# -----------------------------------------------------------------------------
# Hugging Face
# -----------------------------------------------------------------------------
HF_TOKEN=                                    # Hugging Face API token for gated models
HF_HOME=~/.cache/huggingface                 # Hugging Face cache directory

# -----------------------------------------------------------------------------
# OpenAI (for proxy or fallback)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_ORG_ID=

# -----------------------------------------------------------------------------
# Database (for metadata, conversations, etc.)
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./data/nexus.db       # PostgreSQL: postgresql://user:pass@host:5432/nexus
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# S3 / Object Storage (for model artifacts)
# -----------------------------------------------------------------------------
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=nexus-llm
S3_REGION=us-east-1
