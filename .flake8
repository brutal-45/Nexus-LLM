[flake8]
# Flake8 configuration for Nexus-LLM

# Maximum line length (aligned with Black)
max-line-length = 88

# Maximum complexity (McCabe)
max-complexity = 10

# Error codes to ignore
ignore =
    E203,  # whitespace before ':' (conflicts with black)
    E501,  # line too long (handled by max-line-length)
    W503,  # line break before binary operator (conflicts with black)
    W504,  # line break after binary operator
    D100,  # Missing docstring in public module
    D104,  # Missing docstring in public package
    D107,  # Missing docstring in __init__
    B008,  # Do not perform function calls in argument defaults
    B905,  # zip() without strict= (requires Python 3.10+)

# Error codes to select
select =
    E,     # pycodestyle errors
    W,     # pycodestyle warnings
    F,     # pyflakes
    C,     # mccabe complexity
    B,     # flake8-bugbear
    S,     # flake8-bandit
    SIM,   # flake8-simplify
    C4,    # flake8-comprehensions

# Per-file ignores
per-file-ignores =
    __init__.py:F401,F403
    tests/*:S101,D101,D102,D103
    nexus_llm/cli.py:T201
    scripts/*:T201

# Exclude directories
exclude =
    .git,
    __pycache__,
    build,
    dist,
    *.egg-info,
    .eggs,
    .mypy_cache,
    .pytest_cache,
    .tox,
    .venv,
    venv,
    node_modules,
    docs/_build,

# Maximum number of blank lines
max-blank-lines-within = 1

# Statistics
statistics = True

# Show source code for each error
show-source = True

# Count total errors
count = True
